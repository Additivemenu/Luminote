# --- Backend (Vercel functions) ---

# OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Notion: create an internal integration at https://www.notion.so/profile/integrations
# Then in Notion, open your target database, click "..." → "Connections" → add this integration.
NOTION_API_KEY=secret_...

# OPTIONAL: a database whose pages will be browsable as a list in the app.
# Leave blank to use the "paste a page link" input only.
# Copy from the database URL: notion.so/<workspace>/<DATABASE_ID>?v=...
NOTION_DATABASE_ID=

# --- Frontend (Expo) ---

# Where the Expo app should reach the API.
#   - iOS Simulator / web in same browser → http://localhost:3000
#   - Physical iPhone (Expo Go) → http://<your-mac-LAN-ip>:3000
# Anything prefixed EXPO_PUBLIC_ is inlined into the client bundle at build time.
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000
